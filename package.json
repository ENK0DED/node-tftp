{
  "name": "@enk0ded/tftp",
  "version": "0.2.1",
  "description": "Async-first TFTP client and server for Node.js",
  "keywords": [
    "client",
    "pxe",
    "server",
    "tftp",
    "udp"
  ],
  "homepage": "https://github.com/ENK0DED/node-tftp#readme",
  "bugs": {
    "url": "https://github.com/ENK0DED/node-tftp/issues"
  },
  "license": "MIT",
  "author": "Eloy Rodriguez <officialenkoded@gmail.com>",
  "repository": "https://github.com/ENK0DED/node-tftp",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "release": "bumpp --tag --push",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260419.1",
    "bumpp": "^11.0.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "tsdown": "^0.21.9",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.12"
}
